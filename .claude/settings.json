{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/typecheck.sh",
            "timeout": 60,
            "statusMessage": "Typechecking..."
          }
        ]
      }
    ]
  }
}
